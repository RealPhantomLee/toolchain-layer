# =============================================================================
# .gitignore-starter
# Copy this file to your project root and rename it to .gitignore
# =============================================================================

# --- Private companion and runtime files ------------------------------------
.env
.env.local
.env.*.local
private/
*-PRIVATE/

# --- Secrets ----------------------------------------------------------------
*.key
*.pem
*.crt
*.p12
*.pfx
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
credentials.json
*.secrets
*.secret

# --- Docker runtime data ----------------------------------------------------
docker-data/
data/
volumes/

# --- OS and editor cruft ----------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
*.swp
*.swo
*~
.vscode/
.idea/
*.iml

# --- Node.js ----------------------------------------------------------------
node_modules/
npm-debug.log
npm-debug.log.*
yarn-debug.log
yarn-debug.log.*
yarn-error.log
yarn-error.log.*
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
dist/
build/
.next/
.nuxt/

# --- Python -----------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml

# --- Logs -------------------------------------------------------------------
*.log
logs/
